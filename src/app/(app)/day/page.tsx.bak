"use client";

import React, { useMemo } from "react";
import { useFirebaseDataContext } from "@/components/FirebaseDataContext";

export default function DayTradingPage(): React.ReactElement {
  const { ipos } = useFirebaseDataContext();
  const activeIpos = useMemo(() => {
    const list = (ipos || []).filter((ipo: any) => ipo.status === "Talep Toplanıyor" || ipo.status === "Yolda");
    return list;
  }, [ipos]);

  const count = activeIpos.length;
  return (
    <div className="space-y-4 pb-10">
      <div className="flex items-center justify-between">
        <h1 className="text-xl font-black">Günlük Arzlar</h1>
        <span className="text-xs text-zinc-500">Aktif arz: {count}</span>
      </div>
      <div className="grid grid-cols-1 gap-2">
        {activeIpos.map((ipo: any) => (
          <div key={ipo.id} className="flex items-center justify-between p-2 border rounded">
            <span>{ipo.ticker}</span>
            <span>₺{Number(ipo.price || 0).toLocaleString(undefined, { maximumFractionDigits: 2 })}</span>
          </div>
        ))}
        {count === 0 && (
          <div className="text-zinc-500 text-sm">Aktif arz bulunmuyor</div>
        )}
      </div>
    </div>
  );
}
